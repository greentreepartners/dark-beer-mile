---
interface Props {
	id: string;
	label: string;
}

const { id, label } = Astro.props;
---

<div
	class="hero-detail-panel"
	id={id}
	aria-hidden="true"
	aria-labelledby={`${id}-label`}
>
	<p class="hero-detail-panel__sr-label" id={`${id}-label`}>{label}</p>
	<div class="hero-detail-panel__content">
		<slot />
	</div>
</div>

<style>
	.hero-detail-panel {
		position: absolute;
		top: calc(100% + clamp(1.25rem, 4vw, 2.5rem));
		left: 0;
		width: 100%;
		max-height: calc(
			50vh - clamp(3.3rem, 12vw, 8.25rem) * 0.5 - clamp(1.25rem, 4vw, 2.5rem)
		);
		overflow-y: auto;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 350ms linear, visibility 0s linear 350ms;
	}

	.hero-detail-panel.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition: opacity 350ms linear, visibility 0s linear 0s;
	}

	.hero-detail-panel__sr-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.hero-detail-panel__content {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-detail-panel {
			transition: none;
		}
	}
</style>
