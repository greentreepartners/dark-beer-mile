---
interface Props {
	id: string;
	label: string;
}

const { id, label } = Astro.props;
---

<div
	class="hero-detail-panel"
	id={id}
	aria-hidden="true"
	aria-labelledby={`${id}-label`}
>
	<p class="hero-detail-panel__sr-label" id={`${id}-label`}>{label}</p>
	<div class="hero-detail-panel__content">
		<slot />
	</div>
</div>

<style>
	.hero-detail-panel {
		position: absolute;
		top: calc(100% + clamp(1.75rem, 5vw, 3rem));
		left: 0;
		z-index: 1;
		width: 100%;
		max-height: var(
			--hero-panel-max-height,
			min(50vh, calc(100dvh - 50% + clamp(3.3rem, 12vw, 8.25rem) - clamp(6rem, 18vw, 10rem)))
		);
		overflow-x: hidden;
		overflow-y: hidden;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 350ms linear, visibility 0s linear 350ms;
	}

	.hero-detail-panel.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition: opacity 350ms linear, visibility 0s linear 0s;
	}

	/** Scroll only for legends list or reduced-motion static beat dumps. */
	.hero-detail-panel.is-open:has(.beat-panel.is-reduced-motion),
	.hero-detail-panel.is-open:has(.legends) {
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
	}

	@media (max-width: 768px) {
		.hero-detail-panel {
			top: calc(100% + clamp(1.5rem, 4.5vw, 2.5rem));
			padding-inline: 0.15rem;
		}
	}

	@media (max-width: 430px) {
		.hero-detail-panel {
			top: calc(100% + clamp(1.35rem, 4vw, 2rem));
		}
	}

	.hero-detail-panel__sr-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.hero-detail-panel__content {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-detail-panel {
			transition: none;
		}
	}
</style>
