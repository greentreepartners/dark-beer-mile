---
/**
 * FoamLineRunner — cream silhouette crosses the foam/stout line once after hero title.
 * Primary: CSS sprite sheet (iOS-safe). Optional WebM enhancement on desktop when supported.
 * Sprite: public/runner-sprite.png (24 frames × 298×168, extracted from runner-foam.webm).
 */
interface Props {
	durationMs?: number;
	spriteSrc?: string;
	videoSrc?: string;
	frameCount?: number;
}

const {
	durationMs = 10000,
	spriteSrc = '/runner-sprite.png',
	videoSrc = '/runner-foam.webm',
	frameCount = 24,
} = Astro.props;

/** One full sprite cycle ≈ 5s source clip; cross is ~10s so stride loops twice. */
const strideDurationMs = 5000;
---

<div class="foam-line-runner" hidden aria-hidden="true">
	<div class="foam-line-runner__track">
		<div
			class="foam-line-runner__sprite"
			style={`--runner-duration: ${durationMs}ms; --stride-duration: ${strideDurationMs}ms; --frame-count: ${frameCount}`}
		>
			<span class="foam-line-runner__figure" aria-hidden="true"></span>
			<video
				class="foam-line-runner__video"
				src={videoSrc}
				muted
				playsinline
				preload="auto"
				loop
				hidden
			></video>
		</div>
	</div>
</div>

<style>
	.foam-line-runner {
		position: absolute;
		inset: 0;
		z-index: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.foam-line-runner__track {
		position: absolute;
		left: 0;
		right: 0;
		top: var(--foam-line-y, 32%);
		height: 0;
	}

	/* Bottom edge of sprite sits on foam line (feet on track Y). */
	.foam-line-runner__sprite {
		position: absolute;
		left: 0;
		bottom: 0;
		height: clamp(2.97rem, 10.56vh, 7.26rem);
		transform: translateX(-120%);
		will-change: transform;
	}

	.foam-line-runner__sprite.is-running {
		animation: foam-runner-cross var(--runner-duration, 10000ms) linear forwards;
	}

	.foam-line-runner__figure {
		display: block;
		height: 100%;
		aspect-ratio: 298 / 168;
		background-image: url('/runner-sprite.png');
		background-repeat: no-repeat;
		background-size: calc(100% * var(--frame-count, 24)) 100%;
		background-position: 0 0;
	}

	.foam-line-runner__sprite.is-running .foam-line-runner__figure {
		animation: foam-runner-stride var(--stride-duration, 5000ms) steps(23) infinite;
	}

	.foam-line-runner__video {
		display: none;
		height: 100%;
		width: auto;
		pointer-events: none;
	}

	.foam-line-runner.is-video-enhanced .foam-line-runner__figure {
		display: none;
	}

	.foam-line-runner.is-video-enhanced .foam-line-runner__video {
		display: block;
	}

	@keyframes foam-runner-cross {
		from {
			transform: translate3d(-120%, 0, 0);
		}

		to {
			transform: translate3d(calc(100vw + 120%), 0, 0);
		}
	}

	@keyframes foam-runner-stride {
		from {
			background-position: 0 0;
		}

		to {
			background-position: 100% 0;
		}
	}

</style>

<script>
	function bindFoamLineRunner() {
		const hero = document.querySelector('.cinematic-hero');
		const runner = document.querySelector('.foam-line-runner');
		if (!hero || !runner) return;

		const sprite = runner.querySelector('.foam-line-runner__sprite');
		const video = runner.querySelector('.foam-line-runner__video');
		if (!(sprite instanceof HTMLElement)) return;

		const crossDurationSec =
			parseInt(getComputedStyle(sprite).getPropertyValue('--runner-duration'), 10) / 1000 || 10;

		const LEG_CYCLE_MULTIPLIER = 1.33 * 1.5;

		const tryVideoEnhancement = () => {
			if (!(video instanceof HTMLVideoElement)) return;
			if (!window.matchMedia('(min-width: 768px)').matches) return;

			const syncVideoPlaybackRate = () => {
				if (!Number.isFinite(video.duration) || video.duration <= 0) return;
				video.playbackRate = (video.duration / crossDurationSec) * LEG_CYCLE_MULTIPLIER;
			};

			video.addEventListener('loadedmetadata', syncVideoPlaybackRate, { once: true });
			video.hidden = false;
			video.play()
				.then(() => {
					syncVideoPlaybackRate();
					runner.classList.add('is-video-enhanced');
				})
				.catch(() => {
					video.hidden = true;
					runner.classList.remove('is-video-enhanced');
				});
		};

		const startRunner = () => {
			if (sprite.classList.contains('is-running')) return;

			runner.hidden = false;
			sprite.classList.remove('is-running');
			void sprite.offsetWidth;

			if (video instanceof HTMLVideoElement && runner.classList.contains('is-video-enhanced')) {
				video.currentTime = 0;
				video.play().catch(() => {});
			}

			sprite.classList.add('is-running');
		};

		const onAnimationEnd = (event: AnimationEvent) => {
			if (event.target !== sprite) return;
			sprite.classList.remove('is-running');
			if (video instanceof HTMLVideoElement) video.pause();
			runner.hidden = true;
		};

		sprite.removeEventListener('animationend', onAnimationEnd);
		sprite.addEventListener('animationend', onAnimationEnd);

		tryVideoEnhancement();

		hero.removeEventListener('dbm:hero-title-visible', startRunner);
		hero.addEventListener('dbm:hero-title-visible', startRunner, { once: true });

		if (hero.classList.contains('is-complete')) {
			startRunner();
		}
	}

	function bootFoamLineRunner() {
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', bindFoamLineRunner, { once: true });
		} else {
			bindFoamLineRunner();
		}
	}

	bootFoamLineRunner();
	document.addEventListener('astro:page-load', bindFoamLineRunner);
</script>
