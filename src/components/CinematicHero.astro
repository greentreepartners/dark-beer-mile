---
/**
 * CinematicHero — full-viewport landing hero with sequenced tagline reveal.
 * Single hero-line element; client script sequences fade out → gap → text swap → fade in.
 */
import FoamLineRunner from './FoamLineRunner.astro';
import GuinnessSurge from './GuinnessSurge.astro';
import HeroPanels from './HeroPanels.astro';

const IN_MS = 1700;
const OUT_MS = 700;
/** ms with no hero line visible between line N out and line N+1 in */
const LINE_GAP_MS = 300;
const INITIAL_DELAY_MS = 400;

const lineDefs = [
	{ lines: [[{ text: 'One mile' }]], hold: 650 },
	{ lines: [[{ text: 'One night' }]], hold: 650 },
	{
		lines: [
			[{ text: 'Poured' }],
			[{ text: 'in ' }, { text: 'darkness' }],
		],
		hold: 800,
	},
	{
		lines: [
			[{ text: 'One head' }],
			[{ text: 'will ' }, { text: 'rise' }],
		],
		hold: 1100,
	},
] as const;
---

<section class="cinematic-hero" aria-label="Hero">
	<div class="hero-surface" aria-hidden="true">
		<GuinnessSurge />
	</div>

	<FoamLineRunner />

	<div class="hero-stage">
		<div class="hero-anchor" aria-live="polite">
			<div class="hero-sequence">
				<p class="hero-line" id="hero-line"></p>
				<p class="hero-line hero-title" id="hero-title">Dark Beer Mile</p>
			</div>
			<div class="hero-vertical-divider" aria-hidden="true"></div>
			<HeroPanels />
		</div>
	</div>

	<div class="hero-lockup">
		<p class="hero-lockup__tagline">
			<button
				type="button"
				class="hero-lockup__item"
				data-hero-panel="mile-panel"
				aria-label="One mile"
				aria-expanded="false"
				aria-controls="mile-panel"
			>
				<span class="hero-lockup__label hero-lockup__label--long">One mile</span>
				<span class="hero-lockup__label hero-lockup__label--short">Mile</span>
			</button>
			<span class="hero-lockup__sep" aria-hidden="true">|</span>
			<button
				type="button"
				class="hero-lockup__item"
				data-hero-panel="night-panel"
				aria-label="One night"
				aria-expanded="false"
				aria-controls="night-panel"
			>
				<span class="hero-lockup__label hero-lockup__label--long">One night</span>
				<span class="hero-lockup__label hero-lockup__label--short">Night</span>
			</button>
			<span class="hero-lockup__sep" aria-hidden="true">|</span>
			<button
				type="button"
				class="hero-lockup__item"
				data-hero-panel="darkness-panel"
				aria-label="Poured in darkness"
				aria-expanded="false"
				aria-controls="darkness-panel"
			>
				<span class="hero-lockup__label hero-lockup__label--long">Poured in darkness</span>
				<span class="hero-lockup__label hero-lockup__label--short">Darkness</span>
			</button>
			<span class="hero-lockup__sep" aria-hidden="true">|</span>
			<button
				type="button"
				class="hero-lockup__item"
				data-hero-panel="legends-panel"
				aria-label="One head will rise"
				aria-expanded="false"
				aria-controls="legends-panel"
			>
				<span class="hero-lockup__label hero-lockup__label--long"
					>One head will <span class="hero-lockup__accent">rise</span></span
				>
				<span class="hero-lockup__label hero-lockup__label--short">Legends</span>
			</button>
		</p>
	</div>
</section>

<style>
	.cinematic-hero {
		--stout-core: #0a0402;
		--stout-body: #1a0601;
		--rust-dark: #3a1208;
		--amber: #8b3a10;
		--foam: #f2dea3;
		/** Foam/stout boundary — matches GuinnessSurge foam band (~29% from top). */
		--foam-line-y: 29%;
		--amber-bright: #d4a060;
		--foam-subtle: rgba(242, 222, 163, 0.8);
		--foam-border: rgba(242, 222, 163, 0.15);
		--hero-in-ms: 1700ms;
		--hero-out-ms: 700ms;
		--lockup-duration: 1600ms;
		--hero-footer-height: 0px;
		/** Two-line title/tagline block — reserve height for wrapped Dark Beer Mile. */
		--hero-title-height: clamp(6.6rem, 24vw, 16.5rem);
		/** Nudge anchor up from dead-center — middle ground between 50% and full title-height shift. */
		--hero-anchor-offset: calc(var(--hero-title-height) * 0.35);
		--hero-panel-max-height: min(
			50vh,
			calc(100dvh - 50% + var(--hero-title-height) - clamp(6rem, 18vw, 10rem))
		);

		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 100vh;
		min-height: 100dvh;
		overflow-x: clip;
		overflow-y: hidden;
		background: var(--stout-core);
		color: var(--foam);
	}

	.cinematic-hero:has(.hero-detail-panel.is-open) {
		overflow: visible;
	}

	.hero-surface {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		opacity: 1;
		transform: none;
	}

	.hero-stage {
		position: relative;
		z-index: 1;
		width: 100%;
		min-height: inherit;
		padding: 2rem;
	}

	/** Fixed viewport anchor — title stays pinned; legends overlay below without reflow. */
	.hero-anchor {
		position: absolute;
		top: calc(50% - var(--hero-anchor-offset));
		left: 50%;
		z-index: 2;
		width: min(calc(100% - 4rem), 64rem);
		height: auto;
		min-height: var(--hero-title-height);
		transform: translate(-50%, -50%);
		overflow: visible;
	}

	.hero-sequence {
		position: relative;
		z-index: 2;
		width: 100%;
		min-height: var(--hero-title-height);
	}

	.hero-line {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: clamp(3.3rem, 12vw, 8.25rem);
		font-weight: 900;
		line-height: 1.05;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		text-align: center;
		color: var(--foam);
		white-space: nowrap;
	}

	/** Fade/blur/scale on content-sized wrapper — not the full-height slot. */
	.hero-line :global(.hero-line__fx) {
		display: block;
		transform-origin: center center;
		opacity: 0;
		visibility: hidden;
		filter: blur(6px);
		transform: scale(0.92);
	}

	.hero-line :global(.hero-line__fx.is-visible) {
		opacity: 1;
		visibility: visible;
		filter: blur(0);
		transform: scale(1);
	}

	.hero-title {
		font-size: clamp(3.3rem, 12vw, 8.25rem);
		max-width: 100%;
		overflow-wrap: break-word;
		text-wrap: balance;
		white-space: normal;
		transform-origin: center center;
		opacity: 0;
		visibility: hidden;
		filter: blur(6px);
		transform: scale(0.92);
	}

	.hero-title.is-visible {
		opacity: 1;
		visibility: visible;
		filter: blur(0);
		transform: scale(1);
	}
	.hero-line :global(.hero-line__accent) {
		color: var(--amber-bright);
	}

	.hero-line :global(.hero-line__text) {
		display: block;
		text-align: center;
		line-height: 1.05;
		white-space: normal;
	}

	.hero-line :global(.hero-line__text--stacked) {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0;
		min-height: calc(2.1em + 0.08em);
		line-height: 1.05;
		white-space: normal;
	}

	.hero-line :global(.hero-line__row) {
		display: block;
		width: 100%;
		text-align: center;
		line-height: 1.05;
	}

	.hero-line :global(.hero-line__row + .hero-line__row) {
		margin-top: 0.08em;
	}

	.hero-vertical-divider {
		position: absolute;
		top: calc(100% + clamp(0.35rem, 1.2vw, 0.65rem));
		left: 50%;
		width: 1px;
		height: clamp(1.5rem, 5vh, 2.75rem);
		transform: translateX(-50%);
		background: linear-gradient(
			180deg,
			transparent 0%,
			var(--foam-border) 20%,
			var(--foam-border) 80%,
			transparent 100%
		);
		opacity: 0.55;
		pointer-events: none;
	}

	.hero-lockup {
		position: absolute;
		left: 50%;
		bottom: 9%;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		width: min(92vw, 42rem);
		transform: translateX(-50%);
		opacity: 0;
		pointer-events: none;
		text-align: center;
	}

	.cinematic-hero.is-complete .hero-lockup {
		pointer-events: auto;
	}

	.cinematic-hero.is-complete .hero-lockup {
		animation: hero-lockup-in var(--lockup-duration) ease forwards;
	}

	.hero-lockup__tagline {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.35rem 0.55rem;
		margin: 0;
		padding: 0.55rem 1.1rem;
		font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
		font-size: clamp(0.62rem, 1.9vw, 0.85rem);
		font-weight: 600;
		line-height: 1.4;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--amber-bright);
	}

	.hero-lockup__sep {
		opacity: 0.45;
		user-select: none;
	}

	.hero-lockup__item {
		border: 0;
		padding: 0;
		background: transparent;
		font: inherit;
		letter-spacing: inherit;
		text-transform: inherit;
		color: rgba(212, 160, 96, 0.78);
		white-space: nowrap;
		cursor: pointer;
		text-decoration: underline;
		text-decoration-color: var(--amber-bright);
		text-decoration-thickness: 1px;
		text-underline-offset: 0.22em;
		transition: color 200ms ease, text-decoration-color 200ms ease;
	}

	.hero-lockup__item.is-active {
		color: var(--foam);
		text-decoration-color: var(--amber-bright);
	}

	.hero-lockup__item:hover,
	.hero-lockup__item:focus-visible {
		color: var(--foam);
		text-decoration-color: var(--amber-bright);
		outline: 1px solid var(--foam-border);
		outline-offset: 3px;
	}

	.hero-lockup__accent {
		color: var(--amber-bright);
	}

	.hero-lockup__label--short {
		display: none;
	}

	@keyframes hero-lockup-in {
		from {
			opacity: 0;
		}

		to {
			opacity: 1;
		}
	}

	@media (max-width: 768px) {
		.hero-lockup__label--long {
			display: none;
		}

		.hero-lockup__label--short {
			display: inline;
		}

		.cinematic-hero {
			--hero-title-height: clamp(8.5rem, 30vw, 12rem);
			--hero-footer-height: calc(3.5rem + env(safe-area-inset-bottom, 0px));
			--hero-panel-max-height: calc(
				100dvh - 50% + var(--hero-title-height) - var(--hero-footer-height) -
					clamp(3.5rem, 14vw, 5.5rem)
			);
			padding-bottom: var(--hero-footer-height);
		}

		.hero-stage {
			padding: 1.25rem 1rem;
		}

		.hero-anchor {
			width: min(calc(100% - 1.5rem), 64rem);
		}

		.hero-line,
		.hero-title {
			font-size: clamp(2.75rem, 11vw, 5.5rem);
			white-space: normal;
			hyphens: none;
			padding-inline: 0.15rem;
		}

		.hero-lockup {
			position: fixed;
			left: 0;
			right: 0;
			bottom: 0;
			z-index: 10;
			width: 100%;
			max-width: none;
			transform: none;
			padding-bottom: env(safe-area-inset-bottom, 0px);
			background: linear-gradient(
				180deg,
				transparent 0%,
				rgba(10, 4, 2, 0.82) 28%,
				rgba(10, 4, 2, 0.96) 100%
			);
		}

		.hero-lockup__tagline {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 0;
			width: 100%;
			max-width: 100%;
			padding: 0.35rem 0.5rem 0.45rem;
			font-size: clamp(0.62rem, 2.8vw, 0.78rem);
		}

		.hero-lockup__sep {
			display: none;
		}

		.hero-lockup__item {
			display: flex;
			align-items: center;
			justify-content: center;
			min-height: 44px;
			padding-inline: 0.15rem;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
			text-align: center;
		}

		.hero-lockup__item.is-active {
			color: var(--foam);
			text-decoration-color: var(--foam);
			text-decoration-thickness: 2px;
		}
	}

	@media (max-width: 430px) {
		.cinematic-hero {
			/** Two-line title wrap — reserve height so panels stay below. */
			--hero-title-height: clamp(5.75rem, 26vw, 7.5rem);
		}

		.hero-line,
		.hero-title {
			font-size: clamp(2.75rem, 13vw, 4rem);
			letter-spacing: 0.015em;
		}
	}

	@media (max-width: 375px) {
		.cinematic-hero {
			--hero-title-height: clamp(6.25rem, 28vw, 8rem);
		}

		.hero-line,
		.hero-title {
			font-size: clamp(2.5rem, 12vw, 3.65rem);
			line-height: 1.1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-line :global(.hero-line__fx),
		.hero-title {
			filter: none;
		}
	}
</style>

<script
	define:vars={{
		lineDefs,
		IN_MS,
		OUT_MS,
		LINE_GAP_MS,
		INITIAL_DELAY_MS,
	}}
>
	function partToHtml(part) {
		return part.accent
			? `<span class="hero-line__accent">${part.text}</span>`
			: part.text;
	}

	function partsToHtml(line) {
		const rows = line.lines
			.map((parts) => {
				const inner = parts.map(partToHtml).join('');
				return `<span class="hero-line__row">${inner}</span>`;
			})
			.join('');
		const stackedClass =
			line.lines.length > 1 ? ' hero-line__text--stacked' : '';
		return `<span class="hero-line__fx"><span class="hero-line__text${stackedClass}">${rows}</span></span>`;
	}

	function getFadeTarget(el) {
		return el.querySelector('.hero-line__fx') ?? el;
	}

	function wait(ms, signal) {
		return new Promise((resolve, reject) => {
			if (signal?.aborted) {
				reject(signal.reason ?? new DOMException('Aborted', 'AbortError'));
				return;
			}
			const id = setTimeout(resolve, ms);
			signal?.addEventListener(
				'abort',
				() => {
					clearTimeout(id);
					reject(signal.reason ?? new DOMException('Aborted', 'AbortError'));
				},
				{ once: true },
			);
		});
	}

	function waitForTransition(el, fallbackMs, signal) {
		return new Promise((resolve, reject) => {
			if (signal?.aborted) {
				reject(signal.reason ?? new DOMException('Aborted', 'AbortError'));
				return;
			}
			let settled = false;
			const finish = () => {
				if (settled) return;
				settled = true;
				el.removeEventListener('transitionend', onEnd);
				signal?.removeEventListener('abort', onAbort);
				resolve();
			};
			const onEnd = (event) => {
				if (event.target === el) finish();
			};
			const onAbort = () => {
				el.removeEventListener('transitionend', onEnd);
				reject(signal.reason ?? new DOMException('Aborted', 'AbortError'));
			};
			el.addEventListener('transitionend', onEnd);
			signal?.addEventListener('abort', onAbort, { once: true });
			setTimeout(finish, fallbackMs + 50);
		});
	}

	function setFadeOutTransition(el) {
		el.style.transition = [
			`opacity ${OUT_MS}ms linear`,
			`filter ${OUT_MS}ms linear`,
			`transform ${OUT_MS}ms linear`,
			`visibility 0s linear ${OUT_MS}ms`,
		].join(', ');
	}

	function setFadeInTransition(el) {
		el.style.transition = [
			`opacity ${IN_MS}ms linear`,
			`filter ${IN_MS}ms linear`,
			`transform ${IN_MS}ms linear`,
			`visibility 0s linear 0s`,
		].join(', ');
	}

	async function fadeOut(el, signal) {
		const target = getFadeTarget(el);
		setFadeOutTransition(target);
		target.classList.remove('is-visible');
		await waitForTransition(target, OUT_MS, signal);
		target.style.removeProperty('visibility');
		target.style.removeProperty('filter');
		target.style.removeProperty('transform');
	}

	async function fadeIn(el, signal) {
		const target = getFadeTarget(el);
		target.style.removeProperty('filter');
		target.style.removeProperty('transform');
		target.style.visibility = 'visible';
		setFadeInTransition(target);
		await wait(0, signal);
		target.classList.add('is-visible');
		await waitForTransition(target, IN_MS, signal);
		target.style.removeProperty('visibility');
	}

	async function runHeroSequence(signal) {
		const hero = document.querySelector('.cinematic-hero');
		const el = document.getElementById('hero-line');
		const titleEl = document.getElementById('hero-title');
		if (!hero || !el || !titleEl) return;

		hero.classList.remove('is-complete');
		titleEl.classList.remove('is-visible');
		titleEl.style.removeProperty('visibility');
		titleEl.style.removeProperty('transition');
		el.innerHTML = '';
		el.style.removeProperty('visibility');
		el.style.removeProperty('transition');

		await wait(INITIAL_DELAY_MS, signal);

		for (let i = 0; i < lineDefs.length; i += 1) {
			const line = lineDefs[i];

			if (i > 0) {
				await fadeOut(el, signal);
				await wait(LINE_GAP_MS, signal);
				el.innerHTML = partsToHtml(line);
			} else {
				el.innerHTML = partsToHtml(line);
			}

			await fadeIn(el, signal);
			await wait(line.hold, signal);
		}

		await fadeOut(el, signal);
		el.innerHTML = '';
		await fadeIn(titleEl, signal);
		hero.classList.add('is-complete');
		hero.dispatchEvent(new CustomEvent('dbm:hero-title-visible'));
	}

	function startHeroSequence() {
		window.__dbmHeroAbort?.abort();
		const controller = new AbortController();
		window.__dbmHeroAbort = controller;
		runHeroSequence(controller.signal).catch((err) => {
			if (err?.name !== 'AbortError') throw err;
		});
	}

	function bootHeroSequence() {
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', startHeroSequence, { once: true });
			return;
		}

		startHeroSequence();
	}

	bootHeroSequence();
	document.addEventListener('astro:page-load', bootHeroSequence);
</script>
